# Environment
NODE_ENV=production

# GitHub Container Registry
GITHUB_REPOSITORY=your-org/sicoe

# Database
DB_USERNAME=sicoe_prod_user
DB_PASSWORD=change-this-very-secure-password-prod-minimum-64-chars
DB_DATABASE=sicoe_prod_db

# Backend
BACKEND_URL=https://api.sicoe.example.com
JWT_SECRET=change-this-jwt-secret-key-minimum-64-chars-prod-very-secure
JWT_REFRESH_SECRET=change-this-refresh-secret-key-minimum-64-chars-prod-very-secure

# Frontend
FRONTEND_URL=https://sicoe.example.com
CORS_ORIGIN=https://sicoe.example.com

# Microsoft EntraID (Azure AD)
AZURE_CLIENT_ID=your-prod-azure-client-id
AZURE_TENANT_ID=your-prod-azure-tenant-id
AZURE_CLIENT_SECRET=your-prod-azure-client-secret
