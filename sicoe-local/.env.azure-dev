##################################################
# BACKEND - Azure Development Environment
##################################################

NODE_ENV=development
APP_NAME=SICOE Backend

# PostgreSQL Azure
DB_HOST=<azure-postgres-host>.postgres.database.azure.com
DB_PORT=5432
DB_USERNAME=sicoe_dev_user
DB_PASSWORD=<secure-password>
DB_DATABASE=sicoe_dev_db
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# JWT Authentication
JWT_SECRET=<jwt-secret-minimum-32-chars>
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Azure Active Directory
AZURE_AD_TENANT_ID=<tenant-id>
AZURE_AD_CLIENT_ID=<client-id>
AZURE_AD_CLIENT_SECRET=<client-secret>
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/callback

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Email SMTP
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=<email-user>
EMAIL_PASSWORD=<email-password>
EMAIL_FROM=SICOE <noreply@sicoe.com>

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account-name>;AccountKey=<account-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_MEDIA_CONTAINER=media
AZURE_STORAGE_GENERIC_CONTAINER=storage

# GitHub (Deploy)
GITHUB_REPOSITORY=your-org/sicoe

##################################################
# FRONTEND - Azure Development Environment
##################################################

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_ENV=development
VITE_APP_NAME=SICOE - Desenvolvimento
