# Application
NODE_ENV=local
PORT=3000
APP_NAME=SICOE Backend

# Database
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sicoe_user
DB_PASSWORD=sicoe_password
DB_DATABASE=sicoe_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Microsoft EntraID (preparar para integração)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/callback

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# Security
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Email Configuration (para futuro)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@sicoe.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=SICOE <noreply@sicoe.com>
